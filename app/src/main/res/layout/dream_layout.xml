<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/dream_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:weightSum="100"
    tools:ignore="Overdraw">

    <!-- SEKCJA 1: CZAS (45%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="45"
        android:gravity="center"
        android:orientation="vertical">

        <TextClock
            android:id="@+id/digital_clock"
            android:layout_width="wrap_content"
            android:layout_height="127dp"
            android:fontFamily="sans-serif-light"
            android:format12Hour="HH:mm"
            android:format24Hour="HH:mm"
            android:importantForAccessibility="yes"
            android:textColor="#FF0000"
            android:textSize="116sp"
            android:textStyle="bold" />

        <TextClock
            android:id="@+id/day_of_week"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-8dp"
            android:fontFamily="sans-serif-medium"
            android:format12Hour="EEEE"
            android:format24Hour="EEEE"
            android:textAllCaps="true"
            android:textColor="#FF0000"
            android:textSize="22sp" />
    </LinearLayout>

    <!-- SEKCJA 2: KALENDARZ I SIATKA MIESIĄCA (50%) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="50"
        android:baselineAligned="false"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:weightSum="2">

        <!-- Lewa strona: Wydarzenia -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <TextView
                android:id="@+id/events_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-thin"
                android:text="@string/no_events"
                android:textColor="#FF0000"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Prawa strona: Graficzny kalendarz -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.8"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/month_grid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:gravity="end"
                android:lineSpacingExtra="4dp"
                android:textColor="#FF0000"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- SEKCJA 3: STATUS (5%) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:background="#0A0000"
        android:paddingStart="24dp"
        android:paddingEnd="24dp">

        <TextView
            android:id="@+id/status_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="@string/battery_placeholder"
            android:textColor="#00FF00"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/weather_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="@string/weather_loading"
            android:textColor="#FF0000"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/alarm_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="@string/alarm_none"
            android:textColor="#FF8800"
            android:textSize="14sp" />
    </RelativeLayout>
</LinearLayout>
